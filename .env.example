# --- Steam ---
# Get it at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Your SteamID64 (17 digits). You can find it at https://steamid.io
# by pasting the URL of your Steam profile.
STEAM_ID=


# --- Discord ---
DISCORD_APP_ID=
DISCORD_USER_ID=
DISCORD_BOT_TOKEN=

# Opcional: nombre que aparece arriba del widget. Si se deja vacío,
# se usa tu nombre de Steam.
DISCORD_WIDGET_USERNAME=

# --- SteamGridDB (optional but recommended) ---
# Provides high-resolution game icons (512x512+) so they don't look
# blurry. Get it at https://www.steamgriddb.com/profile/preferences/api
# If left blank, Steam’s app icon (32x32) is used as a fallback.
STEAMGRIDDB_API_KEY=


# Keep all of this PRIVATE! DO NOT SHARE! 